{
  "rules": [
    {
      "key": "spec-git",
      "patterns": [
        "repo",
        "repository",
        "git",
        "github",
        "gitlab",
        "branch",
        "commit",
        "mr",
        "pr",
        "changelog",
        "tag release"
      ]
    },
    {
      "key": "spec-iac",
      "patterns": [
        "iac",
        "terraform",
        "terragrunt",
        "iam",
        "vpc",
        "policy",
        "módulo",
        "modulo",
        "repo iac",
        "infra as code"
      ]
    }
  ]
}